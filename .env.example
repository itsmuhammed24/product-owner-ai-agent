# Variables d'environnement

# === LLM (Groq — gratuit, rapide) ===
# Clé API : https://console.groq.com
GROQ_API_KEY=

# Modèle (optionnel) : llama-3.1-8b-instant, llama-3.3-70b-versatile...
# GROQ_MODEL=llama-3.1-8b-instant

# Clustering sémantique InsightAgent (optionnel) — regroupe les demandes similaires
# Sans clé : 1 requête = 1 insight. Avec clé : "Add SSO" + "Azure AD auth" → 1 insight
# OPENAI_API_KEY=

# Import Canny — puiser le feedback existant (admin Canny > Settings > API)
# CANNY_API_KEY=
# CANNY_BOARD_ID=6902f7d9-9841-a845-6715-4259a03d6cd3

# Contexte produit (prompts dynamiques)
# PRODUCT_NAME=AcmePM
# TARGET_SEGMENT=mid-market

# Limites (securite / cout)
# MAX_FEEDBACKS=100
# MAX_TEXT_LENGTH=10000
# MAX_INGEST_SIZE_MB=5
# MAX_CHAT_MESSAGE_LENGTH=4000

# === UI React ===
# URL de l'API (pour Vite en prod si différente)
# VITE_API_URL=http://localhost:8000

# CORS — origines autorisées (séparées par virgule). En prod : restreindre (pas *)
# CORS_ORIGINS=*
# Exemple prod : CORS_ORIGINS=https://monapp.com,https://www.monapp.com

# === RAG / Vector Store (aucune clé API) ===
# Chroma : persistance cross-sessions — même modèle que RAG (all-MiniLM-L6-v2)
USE_CHROMA=true
CHROMA_PERSIST_DIR=./data/chroma
# Cache modèles (optionnel, évite ~/.cache) :
# SENTENCE_TRANSFORMERS_HOME=./data/.cache

# === Dev / Debug ===
# Afficher traceback dans les erreurs 500 (ne pas activer en prod)
# DEBUG=false

# Rate limiting (req/min par IP sur /run, /chat, /ingest). 0 = désactivé
# RATE_LIMIT_PER_MIN=20
